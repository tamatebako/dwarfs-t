  "configurePresets": [
    {
      "name": "common-base",
      "hidden": true,
      "description": "Common settings for all presets",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_SHARED_LIBS": "OFF",
        "VCPKG_BUILD": "ON",
        "WITH_LIBDWARFS": "ON",
        "WITH_TOOLS": "ON",
        "WITH_TESTS": "ON",
        "WITH_BENCHMARKS": "ON",
        "ENABLE_PERFMON": "ON",
        "TRY_ENABLE_FLAC": "ON",
        "TRY_ENABLE_BROTLI": "ON",
        "TRY_ENABLE_LZ4": "ON",
        "TRY_ENABLE_LZMA": "ON",
        "ENABLE_RICEPP": "ON",
        "USE_JEMALLOC": "ON"
      },
      "warnings": {
        "dev": true,
        "deprecated": true,
        "uninitialized": true,
        "unusedCli": true,
        "systemVars": false
      },
      "environment": {
        "VCPKG_OVERLAY_PORTS": "${sourceDir}/vcpkg_ports",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/vcpkg_triplets"
      }
    },
    {
      "name": "production-base",
      "hidden": true,
      "description": "Production configuration (FlatBuffers + Legacy Thrift only)",
      "cacheVariables": {
        "VCPKG_MANIFEST_FEATURES": ""
      }
    },
    {
      "name": "experimental-base",
      "hidden": true,
      "description": "Experimental configuration (+ Modern Thrift)",
      "cacheVariables": {
        "DWARFS_WITH_EXPERIMENTAL_THRIFT": "ON",
        "VCPKG_MANIFEST_FEATURES": "modern-thrift"
      }
    },
    {
      "name": "x64-linux-base",
      "hidden": true,
      "inherits": "common-base",
      "description": "Linux x64 base configuration",
      "binaryDir": "${sourceDir}/build-${presetName}",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "environment": {
        "VCPKG_DEFAULT_TRIPLET": "x64-linux",
        "VCPKG_OVERLAY_PORTS": "${sourceDir}/vcpkg_ports",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/vcpkg_triplets"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
