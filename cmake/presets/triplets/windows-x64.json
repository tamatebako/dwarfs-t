{
  "version": 4,
  "configurePresets": [
    {
      "name": "windows-x64-base",
      "hidden": true,
      "inherits": "common-base",
      "description": "Windows x64 base configuration",
      "binaryDir": "${sourceDir}/build-windows-x64-${config}",
      "generator": "Ninja",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl",
        "TRY_ENABLE_FLAC": "ON",
        "TRY_ENABLE_BROTLI": "ON",
        "TRY_ENABLE_LZ4": "ON",
        "TRY_ENABLE_LZMA": "ON",
        "ENABLE_RICEPP": "ON",
        "USE_JEMALLOC": "ON"
      }
    },
    {
      "name": "windows-x64-production",
      "inherits": ["windows-x64-base", "production-overlays"],
      "description": "Windows x64 Production (FlatBuffers + Legacy Thrift)"
    },
    {
      "name": "windows-x64-experimental",
      "inherits": ["windows-x64-base", "experimental-overlays"],
      "description": "Windows x64 Experimental (+ Modern Thrift)"
    }
  ],
  "buildPresets": [
    {
      "name": "windows-x64-production",
      "configurePreset": "windows-x64-production",
      "description": "Build Windows x64 Production"
    },
    {
      "name": "windows-x64-experimental",
      "configurePreset": "windows-x64-experimental",
      "description": "Build Windows x64 Experimental"
    }
  ],
  "testPresets": [
    {
      "name": "windows-x64-production",
      "configurePreset": "windows-x64-production",
      "description": "Test Windows x64 Production",
      "output": {
        "outputOnFailure": true,
        "verbosity": "verbose"
      }
    },
    {
      "name": "windows-x64-experimental",
      "configurePreset": "windows-x64-experimental",
      "description": "Test Windows x64 Experimental",
      "output": {
        "outputOnFailure": true,
        "verbosity": "verbose"
      }
    }
  ]
}
