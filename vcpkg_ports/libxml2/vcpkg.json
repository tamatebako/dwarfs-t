{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "libxml2",
  "version-string": "2.15.1",
  "port-version": 0,
  "description": "Libxml2 is the XML C parser and toolkit developed for the Gnome project.",
  "homepage": "https://gitlab.gnome.org/GNOME/libxml2",
  "license": "MIT",
  "dependencies": [
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    },
    {
      "name": "zlib",
      "platform": "!uwp"
    }
  ],
  "default-features": [
    "zlib"
  ],
  "features": {
    "iconv": {
      "description": "Iconv encoding support",
      "dependencies": [
        "iconv"
      ],
      "supports": "!msys"
    },
    "zlib": {
      "description": "zlib compression support",
      "dependencies": [
        "zlib"
      ]
    },
    "icu": {
      "description": "ICU support",
      "dependencies": [
        "icu"
      ]
    },
    "llvm": {
      "description": "Use llvm for XML manipulation",
      "dependencies": [
        "llvm"
      ]
    },
    "tool": {
      "description": "Build the xmlcatalog and xmllot tools"
    }
  }
}
