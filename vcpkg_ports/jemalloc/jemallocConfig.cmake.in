if(CMAKE_VERSION VERSION_LESS "3.15")
    message(FATAL_ERROR "CMake >= 3.15 required")
endif()

# Allow jemalloc to be found via CMake find_package(CONFIG)

# Create imported target
if(NOT TARGET jemalloc::jemalloc)
    add_library(jemalloc::jemalloc STATIC IMPORTED)
    set_target_properties(jemalloc::jemalloc PROPERTIES
        IMPORTED_CONFIGURATIONS RELEASE
        IMPORTED_LOCATION_RELEASE "${CMAKE_CURRENT_LIST_DIR}/../../lib/${CMAKE_STATIC_LIBRARY_PREFIX}jemalloc${CMAKE_STATIC_LIBRARY_SUFFIX}"
        INTERFACE_INCLUDE_DIRECTORIES "${CMAKE_CURRENT_LIST_DIR}/../../include"
    )

    # Add debug configuration if available
    if(EXISTS "${CMAKE_CURRENT_LIST_DIR}/../../debug/lib/${CMAKE_STATIC_LIBRARY_PREFIX}jemalloc${CMAKE_STATIC_LIBRARY_SUFFIX}")
        set_property(TARGET jemalloc::jemalloc APPEND PROPERTY
            IMPORTED_CONFIGURATIONS DEBUG
        )
        set_target_properties(jemalloc::jemalloc PROPERTIES
            IMPORTED_LOCATION_DEBUG "${CMAKE_CURRENT_LIST_DIR}/../../debug/lib/${CMAKE_STATIC_LIBRARY_PREFIX}jemalloc${CMAKE_STATIC_LIBRARY_SUFFIX}"
        )
    endif()
endif()

# Set version variables
set(jemalloc_VERSION "5.3.0")

# Compatibility with older CMake versions
if(NOT DEFINED jemalloc_FOUND)
    set(jemalloc_FOUND TRUE)
endif()

# Compatibility with find_package arguments
if(NOT DEFINED jemalloc_VERSION)
    set(jemalloc_VERSION "5.3.0")
endif()

# For find_package_handle_standard_args compatibility
include(FindPackageHandleStandardArgs)
find_package_handle_standard_args(jemalloc
    REQUIRED_VARS jemalloc::jemalloc
    VERSION_VAR jemalloc_VERSION
)
