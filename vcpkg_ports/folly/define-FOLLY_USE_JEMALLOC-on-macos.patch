diff --git a/CMakeLists.txt b/CMakeLists.txt
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -114,6 +114,16 @@ if(NOT CMAKE_CXX_STANDARD)
   set(CMAKE_CXX_STANDARD 20)
   set(CMAKE_CXX_STANDARD_REQUIRED ON)
   message(STATUS "setting C++ standard to C++${CMAKE_CXX_STANDARD}")
 endif()

+# Define FOLLY_USE_JEMALLOC when jemalloc is found on non-Windows platforms
+# This ensures Folly's Malloc.h uses jemalloc functions like nallocx and sdallocx
+# On macOS, the system malloc.h would otherwise be used instead of jemalloc
+if(UNIX AND NOT APPLE)
+  # Linux: Check for jemalloc via pkg-config or find_package
+  find_package(PkgConfig QUIET)
+  if(PKG_CONFIG_FOUND)
+    pkg_check_modules(JEMALLOC QUIET IMPORTED_TARGET jemalloc)
+  endif()
+  if(JEMALLOC_FOUND)
+    add_compile_definitions(FOLLY_USE_JEMALLOC)
+    message(STATUS "Found jemalloc, defining FOLLY_USE_JEMALLOC")
+  endif()
+elseif(UNIX AND APPLE)
+  # macOS: Check for jemalloc in vcpkg include path
+  find_path(JEMALLOC_INCLUDE_DIR
+    NAMES jemalloc/jemalloc.h
+    PATHS ${CMAKE_REQUIRED_INCLUDES}
+    NO_DEFAULT_PATH
+  )
+  if(JEMALLOC_INCLUDE_DIR)
+    add_compile_definitions(FOLLY_USE_JEMALLOC)
+    message(STATUS "Found jemalloc headers at ${JEMALLOC_INCLUDE_DIR}, defining FOLLY_USE_JEMALLOC")
+  else()
+    # Fallback: check default paths
+    find_path(JEMALLOC_INCLUDE_DIR NAMES jemalloc/jemalloc.h)
+    if(JEMALLOC_INCLUDE_DIR)
+      add_compile_definitions(FOLLY_USE_JEMALLOC)
+      message(STATUS "Found jemalloc headers (fallback), defining FOLLY_USE_JEMALLOC")
+    endif()
+  endif()
+endif()
+
 if(NOT DEFINED IS_X86_64_ARCH AND ${CMAKE_SYSTEM_PROCESSOR} MATCHES "x86_64|AMD64")
