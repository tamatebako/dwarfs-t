diff --git a/CMakeLists.txt b/CMakeLists.txt
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -83,6 +83,16 @@ if(NOT CMAKE_CXX_STANDARD)
   set(CMAKE_CXX_STANDARD 20)
   set(CMAKE_CXX_STANDARD_REQUIRED ON)
   message(STATUS "setting C++ standard to C++${CMAKE_CXX_STANDARD}")
 endif()

+# Fix posix_memalign conflict with GCC's mm_malloc.h on Linux
+# jemalloc declares posix_memalign with __attribute__((nothrow)) -> noexcept in C++20
+# mm_malloc.h declares it with throw() (deprecated in C++20)
+# When fast_float includes xmmintrin.h, mm_malloc.h gets included and conflicts.
+# By defining _MM_MALLOC_H, we prevent mm_malloc.h from being included,
+# ensuring jemalloc's declaration is used consistently.
+if(UNIX AND NOT APPLE AND NOT ANDROID)
+  add_compile_options($<$<COMPILE_LANGUAGE:CXX>:-D_MM_MALLOC_H>)
+endif()
+
 if(NOT DEFINED IS_X86_64_ARCH AND ${CMAKE_SYSTEM_PROCESSOR} MATCHES "x86_64|AMD64")
   set(IS_X86_64_ARCH TRUE)
 else()
