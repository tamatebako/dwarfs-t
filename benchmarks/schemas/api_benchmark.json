{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "libdwarfs API Benchmark Result",
  "description": "Performance metrics for libdwarfs C++ API operations",
  "type": "object",
  "patternProperties": {
    "^[a-z_]+$": {
      "type": "object",
      "required": ["iterations", "time", "memory"],
      "properties": {
        "iterations": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of benchmark iterations"
        },
        "time": {
          "type": "object",
          "required": ["count", "mean", "median", "stddev", "min", "max"],
          "properties": {
            "count": {
              "type": "integer",
              "description": "Number of time measurements"
            },
            "mean": {
              "type": "number",
              "description": "Mean time in seconds"
            },
            "median": {
              "type": "number",
              "description": "Median time in seconds"
            },
            "stddev": {
              "type": "number",
              "description": "Standard deviation in seconds"
            },
            "min": {
              "type": "number",
              "description": "Minimum time in seconds"
            },
            "max": {
              "type": "number",
              "description": "Maximum time in seconds"
            }
          }
        },
        "memory": {
          "type": "object",
          "required": ["count", "mean", "median", "stddev", "min", "max"],
          "properties": {
            "count": {
              "type": "integer",
              "description": "Number of memory measurements"
            },
            "mean": {
              "type": "number",
              "description": "Mean memory usage in bytes"
            },
            "median": {
              "type": "number",
              "description": "Median memory usage in bytes"
            },
            "stddev": {
              "type": "number",
              "description": "Standard deviation in bytes"
            },
            "min": {
              "type": "number",
              "description": "Minimum memory usage in bytes"
            },
            "max": {
              "type": "number",
              "description": "Maximum memory usage in bytes"
            }
          }
        },
        "throughput_mb_per_sec": {
          "type": "number",
          "minimum": 0,
          "description": "Data throughput in megabytes per second"
        },
        "metadata": {
          "type": "object",
          "description": "Benchmark configuration and context",
          "properties": {
            "image_path": {"type": "string"},
            "cache_size": {"type": "string"},
            "num_workers": {"type": "string"},
            "file_path": {"type": "string"},
            "file_size": {"type": "integer"},
            "data_size": {"type": "integer"},
            "num_files": {"type": "integer"},
            "total_size": {"type": "integer"}
          }
        }
      }
    }
  },
  "examples": [
    {
      "single_file_extraction": {
        "iterations": 3,
        "time": {
          "count": 3,
          "mean": 0.000214,
          "median": 0.000213,
          "stddev": 0.000002,
          "min": 0.000212,
          "max": 0.000216
        },
        "memory": {
          "count": 3,
          "mean": 147456.0,
          "median": 147456.0,
          "stddev": 0.0,
          "min": 147456.0,
          "max": 147456.0
        },
        "throughput_mb_per_sec": 226.17,
        "metadata": {
          "image_path": "test.dff",
          "cache_size": "536870912",
          "num_workers": "4",
          "file_path": "/Porting/Maintainers.pl",
          "file_size": 48451,
          "data_size": 48451
        }
      }
    },
    {
      "full_filesystem_extraction": {
        "iterations": 3,
        "time": {
          "count": 3,
          "mean": 1.489,
          "median": 1.490,
          "stddev": 0.005,
          "min": 1.484,
          "max": 1.494
        },
        "memory": {
          "count": 3,
          "mean": 8847360.0,
          "median": 8847360.0,
          "stddev": 0.0,
          "min": 8847360.0,
          "max": 8847360.0
        },
        "throughput_mb_per_sec": 27.75,
        "metadata": {
          "image_path": "test.dff",
          "cache_size": "1073741824",
          "num_workers": "4",
          "num_files": 6816,
          "total_size": 101171200
        }
      }
    }
  ]
}
